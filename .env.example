# Willard AI - local environment configuration
# Copy this file to ".env" in the project root, fill in the values, then start
# the API server. The web app does NOT read this file - it uses local defaults
# (web on http://localhost:5000, API proxied at /api -> http://localhost:8080).
# The Setup Willard AI.bat script fills this in automatically.

# PostgreSQL connection string (REQUIRED).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Setup Willard AI.bat will ask for your PostgreSQL password and fill this in.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/willard

# Port the API server listens on (REQUIRED).
# The web dev server proxies /api to http://localhost:8080, so keep this at 8080.
PORT=8080

# Secret used to sign session cookies (recommended locally, REQUIRED in production).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Run mode — leave as "development" for a local run.
NODE_ENV=development

# Log verbosity: trace | debug | info | warn | error  (optional, default: info)
LOG_LEVEL=info

# ── Optional: AI / chat features ──────────────────────────────────────────────
# Only needed if you use the AI chat. On Replit these are provided automatically.
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=
