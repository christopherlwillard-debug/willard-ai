modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "organize-helpers-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "e2e-dashboard-scan"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cleanup-queue-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cleanup-execute-tests"

[[workflows.workflow]]
name = "organize-helpers-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && node --experimental-strip-types --test src/__tests__/organize-helpers.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "e2e-dashboard-scan"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node --experimental-strip-types --test e2e/dashboard-after-scan.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "cleanup-queue-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node --experimental-strip-types --test artifacts/api-server/src/__tests__/cleanup-queue.test.ts"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "cleanup-execute-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node --experimental-strip-types --test e2e/cleanup-execute.test.ts"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
